{
  "appId": "tech.buildfaster.conntext-build",
  "productName": "ConnText Build",
  "directories": {
    "buildResources": "resources",
    "output": "release"
  },
  "files": [
    "out/**/*",
    "!node_modules/**/*"
  ],
  "win": {
    "target": ["nsis"],
    "icon": "resources/icon.ico"
  },
  "mac": {
    "target": ["dmg"],
    "icon": "resources/icon.icns"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
